{
  "version": 2,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "functions": {
    "api/**/*": {
      "runtime": "nodejs20.x",
      "maxDuration": 15
    }
  },
  "crons": [
    {
      "path": "/api/cron/cancel-pending-orders",
      "schedule": "0 3 * * *"
    }
  ]
}